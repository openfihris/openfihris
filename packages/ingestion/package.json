{
  "name": "@openfihris/ingestion",
  "version": "0.1.0",
  "description": "Auto-ingestion scripts for crawling and indexing existing AI agent registries",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "ingest": "node dist/cli.js",
    "ingest:dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@openfihris/shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "5.7.3",
    "vitest": "^3.0.4"
  }
}
