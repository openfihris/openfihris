{
  "name": "@openfihris/api",
  "version": "0.1.0",
  "description": "OpenFihris REST API server — Hono on Cloudflare Workers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@openfihris/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "wrangler": "^3.99.0"
  }
}
