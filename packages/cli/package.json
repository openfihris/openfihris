{
  "name": "fihris",
  "version": "0.1.0",
  "description": "CLI for OpenFihris — search, install, and publish AI agents, skills, and prompts across any framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fihris": "./bin/fihris.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "prepack": "tsc"
  },
  "dependencies": {
    "@openfihris/shared": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vitest": "^3.0.4"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "agent-registry",
    "cli",
    "a2a",
    "skills",
    "claude",
    "claude-code",
    "langchain",
    "crewai",
    "autogen",
    "fihris",
    "openfihris"
  ],
  "author": "OpenFihris contributors",
  "license": "MIT",
  "homepage": "https://github.com/openfihris/openfihris/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openfihris/openfihris.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/openfihris/openfihris/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
