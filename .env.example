# OpenFihris Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it's in .gitignore.

# Database (Neon.tech serverless Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Embeddings (OpenAI text-embedding-3-small)
OPENAI_API_KEY=sk-...

# GitHub OAuth (for user login)
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxx

# JWT (for session tokens — use any random 32+ char string)
JWT_SECRET=change-me-to-a-random-string

# Environment
NODE_ENV=development
